# Required
DISCORD_TOKEN=your_bot_token_here

# Optional — override defaults
# Slash commands sync globally (bot.tree.sync()), so the bot works in any
# server it is added to — there is no command prefix.
# DEV_GUILD_ID (optional) additionally syncs commands instantly to one guild
# for development; leave it unset in production. The legacy GUILD_ID env name
# is still accepted as an alias.
# DEV_GUILD_ID=123456789012345678
DATABASE_URL=sqlite+aiosqlite:///data/friendex.db
MARKET_OPEN=06:30
MARKET_CLOSE=04:30
TIMEZONE_OFFSET_HOURS=0

# Game tuning
INITIAL_CASH=10000
INITIAL_PRICE=100
MIN_PRICE=70
PRICE_IMPACT_K=0.5
INACTIVITY_DECAY=0.04
LIQUIDATION_THRESHOLD=1.5
SHORT_FREEZE_MINUTES=30
TRADE_COOLDOWN_SECONDS=900
DISCIPLINE_PENALTY=0.17

# Discord role/channel IDs (comma-separated, snowflake integers)
VC_PING_ROLE_IDS=111111111111111111,222222222222222222,333333333333333333,444444444444444444
PHOTO_BONUS_CHANNEL_IDS=555555555555555555,666666666666666666

# Hedge fund
HEDGE_FUND_BASE_APY=0.15
# Open-Q8 toggle: cadence used by FundService.accrue_apy. "monthly" credits
# balance * apy / 12 per call (historic Phase-8e behaviour); "annual" credits
# the full balance * apy in a single call. Allowed values: monthly | annual.
HEDGE_FUND_BASE_APY_PERIOD=monthly
EARLY_WITHDRAW_PENALTY=0.05
PENALTY_DURATION_DAYS=14

# Trading toggles
# Open-Q2 toggle: when true (default) /buy treats Sunday as a normal trading
# day (preserves the original spec's Sunday-buy exception); set to false to
# make Sunday a fully closed day for /buy as well. /sell, /short and /cover
# always reject Sunday regardless of this flag.
SUNDAY_BUY_ALLOWED=true
# Open-Q3 toggle: when true (default) an opt_in=False target raises OptedOut
# from every trade direction; set to false to make opt-out advisory (the user
# is hidden from opt-in-only listings but trades against them still succeed).
OPT_OUT_BLOCKS_TRADING=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
